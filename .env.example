# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=retention
DB_AUTO_LOAD_ENTITIES=true
DB_SYNCHRONIZE=false

# App
PORT=4001
FRONTEND_URL=http://localhost:3002
PUBLIC_BASE_URL=http://localhost:4001/api
# Max single file upload (bytes). Match nginx client_max_body_size on prod (e.g. 20M).
# UPLOAD_MAX_FILE_BYTES=10485760

# Stripe (platform)
STRIPE_SECRET_KEY=sk_test_xxx
# Required for POST /payment/webhook — from `stripe listen` (whsec_...) or Dashboard webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Platform fee (backend only, cents for USD)
PLATFORM_FEE_FIXED_MINOR=200
# PLATFORM_FEE_PERCENT_BPS=250

# Optional Connect OAuth
# STRIPE_CONNECT_CLIENT_ID=ca_xxx
# STRIPE_CONNECT_REDIRECT_URI=http://localhost:4001/stripe/callback/oauth

# Facebook OAuth (per restaurant — /facebook/*)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Backend callback (or your public frontend /facebook/callback that forwards here)
FACEBOOK_REDIRECT_URI=https://www.dealioo.io/auth/facebook/callback
META_REDIRECT_URI=https://www.dealioo.io/auth/facebook/callback
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# Google OAuth — Login / Register (Passport). Separate from Google Ads.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be the Nest callback (or a proxy that forwards to it):
# http://localhost:4001/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4001/api/auth/google/callback
# Google Ads connect (keep separate from login)
GOOGLE_REDIRECT_URI=https://www.dealioo.io/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_API_VERSION=v22
JWT_SECRET=
FRONTEND_URL=http://localhost:3002

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Brand name shown as SMS sender outside US/Canada (e.g. Dealioo). US/Canada still use TWILIO_PHONE_NUMBER.
TWILIO_SMS_SENDER_NAME=Dealioo
# Full public URL Twilio POSTs to (required behind ngrok for signature validation)
TWILIO_WEBHOOK_PUBLIC_URL=https://www.dealioo.io/api/sms/twilio/inbound
