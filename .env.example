# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=retention
DB_AUTO_LOAD_ENTITIES=true
DB_SYNCHRONIZE=false

# App
PORT=4001

# Automation queue — how many guest runs can process steps at the same time (default 50)
# AUTOMATION_QUEUE_CONCURRENCY=50
# Long waits (≥ threshold) use Postgres scheduled_at + DB poll instead of Redis delayed jobs (default 5 min)
# AUTOMATION_DB_WAIT_THRESHOLD_MS=300000
# AUTOMATION_WAIT_POLL_INTERVAL_MS=60000
FRONTEND_URL=https://your-subdomain.ngrok-free.app
CORS_ORIGIN=https://your-subdomain.ngrok-free.app

# Stripe (platform)
STRIPE_SECRET_KEY=sk_test_xxx
# Required for POST /payment/webhook — from `stripe listen` (whsec_...) or Dashboard webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Platform fee (backend only, cents for USD)
PLATFORM_FEE_FIXED_MINOR=200
# PLATFORM_FEE_PERCENT_BPS=250

# Optional Connect OAuth
# STRIPE_CONNECT_CLIENT_ID=ca_xxx
# STRIPE_CONNECT_REDIRECT_URI=http://localhost:4001/stripe/callback/oauth

# Facebook OAuth (per restaurant — /facebook/*)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Backend callback (or your public frontend /facebook/callback that forwards here)
FACEBOOK_REDIRECT_URI=http://localhost:4001/facebook/callback/oauth
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_API_VERSION=v22
